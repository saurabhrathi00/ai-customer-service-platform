# Copy this to .env on the production host and fill in real values.
# docker compose reads .env automatically. Never commit the real .env.

# Public domain Caddy will terminate TLS for and Twilio will dial.
PUBLIC_HOST=my-domain.in

# Used by Let's Encrypt for cert expiry notices.
ACME_EMAIL=ops@my-domain.in

# Public wss:// URL of call-orchestration-service. This is the value
# incoming-call-service puts into the TwiML <Stream url="..."> tag,
# so it must be reachable from Twilio's network.
CONFIGS_CALLORCHESTRATION_WSBASEURL=wss://my-domain.in/call-orchestration-service
